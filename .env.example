# OpenRouter configuration
# Copy this file to ".env" and fill in your real values.
# The real .env file is git-ignored and must NEVER be committed.

# --- Required: primary API key (slot 1) ---------------------------------------
# Your OpenRouter API key (keep the "sk-or-v1-" prefix)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# --- Optional: extra API keys (slots 2..5) -------------------------------------
# Add up to 4 more OpenRouter accounts to spread the daily free-tier cap across
# 5 keys. Leave any slot empty (or omit it entirely) to skip it. The router
# walks the slots round-robin, so with 5 keys the same message hits each key
# in turn, multiplying the per-day headroom by 5x.
#
# Get more keys by creating more OpenRouter accounts at https://openrouter.ai.
#
# OPENROUTER_API_KEY_2=sk-or-v1-REPLACE_ME
# OPENROUTER_API_KEY_3=sk-or-v1-REPLACE_ME
# OPENROUTER_API_KEY_4=sk-or-v1-REPLACE_ME
# OPENROUTER_API_KEY_5=sk-or-v1-REPLACE_ME

# --- Model pool ---------------------------------------------------------------
# The free model you chose (must match exactly what is shown on openrouter.ai/models)
# Example: google/gemma-4-31b:free
OPENROUTER_MODEL=provider/model-name:free

# Optional: override the model pool with a comma-separated list of free models.
# When set, this list REPLACES OPENROUTER_MODEL entirely. Leave blank (or
# commented) to use the single OPENROUTER_MODEL above. Every id must end in
# ":free" — the router refuses paid models at construction time.
# OPENROUTER_MODELS=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free

# --- Endpoint -----------------------------------------------------------------
# OpenRouter chat completions endpoint
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# --- App identity -------------------------------------------------------------
# Optional: identify your app to OpenRouter (recommended)
OPENROUTER_APP_NAME=AI Security Chatbot (Stage 1)
