# =============================================================================
# SecMentor — Environment Configuration
# =============================================================================
# Copy this file to ".env" and fill in your real values.
# The real .env file is git-ignored and must NEVER be committed.
#
# IMPORTANT: do NOT edit this file in an editor that hard-wraps long lines
# at 80 columns. API keys and model ids are 60-80 characters long; a wrap
# will break them across two lines and python-dotenv will read them as
# truncated. Use an editor with word-wrap OFF, or paste via the terminal.

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# Choose your LLM backend. Options:
#   gemini    — Google Gemini (recommended: 1500 req/day free, all models vision-capable)
#   openrouter — OpenRouter aggregator (many free models, multi-key rotation)
#
# Leave blank to auto-detect: if GEMINI_API_KEY is set, Gemini is used;
# otherwise OpenRouter is used. Set this explicitly to override.
# ACTIVE_PROVIDER=gemini

# =============================================================================
# GOOGLE GEMINI CONFIG (ACTIVE_PROVIDER=gemini)
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# The free tier gives 1500 requests/day for Gemini 2.0 Flash (as of mid-2026).
# All Gemini models natively support vision — no separate model needed.
#
# GEMINI_API_KEY=YOUR_GOOGLE_AI_STUDIO_KEY_HERE

# Optional: override the Gemini model. Default is gemini-2.0-flash.
# GEMINI_MODEL=gemini-2.0-flash

# Optional: comma-separated list of Gemini models (replaces GEMINI_MODEL).
# Example: GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-pro
# GEMINI_MODELS=

# Optional: override the Gemini API base URL (defaults to Google's OpenAI-compatible endpoint).
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# =============================================================================
# OPENROUTER CONFIG (ACTIVE_PROVIDER=openrouter or auto-detected)
# =============================================================================
# Required: primary API key (slot 1).
# Your OpenRouter API key (keep the "sk-or-v1-" prefix).
# Get it from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Optional: extra API keys (slots 2..5) for free-tier rotation.
# Add up to 4 more OpenRouter accounts to spread the daily free-tier cap.
# Leave empty (or omit) to skip. The router walks slots round-robin.
#
# OPENROUTER_API_KEY_2=sk-or-v1-REPLACE_ME
# OPENROUTER_API_KEY_3=sk-or-v1-REPLACE_ME
# OPENROUTER_API_KEY_4=sk-or-v1-REPLACE_ME
# OPENROUTER_API_KEY_5=sk-or-v1-REPLACE_ME

# Model pool — the single-model fallback when OPENROUTER_MODELS is not set.
# Must be a free-tier model id (ends with ":free").
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Optional: comma-separated list of free OpenRouter models.
# When set, REPLACES OPENROUTER_MODEL entirely.
# OPENROUTER_MODELS=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free

# Endpoint (usually no need to change).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# App identity sent to OpenRouter.
OPENROUTER_APP_NAME=SecMentor

# =============================================================================
# OSINT / RECON CONFIG (both providers)
# =============================================================================
# crt.sh kill-switch: set to false to skip the live crt.sh lookup.
# RECON_CRT_SH_ENABLED=false

# Manual subdomain fallback (used when crt.sh is disabled).
# RECON_FALLBACK_SUBDOMAINS=api.example.com,mail.example.com,www.example.com

# crt.sh per-tool timeout (seconds).
# RECON_CRT_SH_TIMEOUT_SECONDS=45

# Optional ipinfo.io token for richer IP lookup results.
# IPINFO_TOKEN=
